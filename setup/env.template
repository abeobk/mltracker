# /etc/mltracker.env — MLTracker production secrets
# -----------------------------------------------------
# Deploy: sudo cp setup/env.template /etc/mltracker.env
#         sudo chmod 600 /etc/mltracker.env
#         sudo chown root:root /etc/mltracker.env
# Then fill in every value marked <...> before starting the service.
# -----------------------------------------------------

# Flask secret key — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-and-paste-here>

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-client-secret>

# Data paths (on the dedicated EBS volume)
DB_PATH=/mnt/mltracker_data/mltracker.db
FILES_DIR=/mnt/mltracker_data/mltracker

# Set to true AFTER certbot has installed the TLS certificate
SESSION_COOKIE_SECURE=false
